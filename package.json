{
  "name": "books",
  "version": "1.0.0",
  "description": "Screenshot lecture notes organizer",
  "main": "main.js",
  "scripts": {
    "start": "ELECTRON_RUN_AS_NODE= electron .",
    "dev": "concurrently \"vite --config vite.config.ts\" \"wait-on http://localhost:5173 && ELECTRON_RUN_AS_NODE= NODE_ENV=development electron .\"",
    "build": "vite build --config vite.config.ts",
    "build:start": "npm run build && npm run start"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.2.1",
    "typescript": "^5.5.3",
    "vite": "^5.4.2",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "electron": "^32.3.3",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "screenshot-desktop": "^1.12.7",
    "uuid": "^10.0.0",
    "zustand": "^4.5.5"
  }
}
